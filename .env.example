# Required: Neon/Postgres content database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Required for /admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Recommended in production. A connected Vercel Blob store provides this automatically
# and Vercel supplies the short-lived VERCEL_OIDC_TOKEN at runtime.
BLOB_STORE_ID=

# Legacy/manual Blob authentication only. Do not generate a random value.
# Without either complete Blob configuration, uploaded PDFs use the database fallback.
BLOB_READ_WRITE_TOKEN=
